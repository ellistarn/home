{
  "$schema": "https://opencode.ai/config.json",
  "model": "amazon-bedrock/us.anthropic.claude-opus-4-6",
  "default_agent": "plan",
  "permission": {
    "external_directory": {
      "~/go/src/github.com/ellistarn/**": "allow"
    }
  },
  "mcp": {
    "builder-mcp": {
      "type": "local",
      "command": [
        "/Users/etarn/.toolbox/bin/builder-mcp",
        "--include-tools",
        "InternalCodeSearch,InternalSearch,ReadInternalWebsites,WorkspaceSearch,WorkspaceGitDetails,BrazilBuildAnalyzerTool"
      ],
      "enabled": true
    },
    "ellis": {
      "type": "local",
      "command": [
        "/Users/etarn/go/bin/muse",
        "listen"
      ],
      "enabled": true,
      "timeout": 120000
    }
  },
  "instructions": [],
  "tools": {
    "builder-mcp_*": true,
    "ellis_*": true
  },
  "agent": {
    "plan": {
      "prompt": "{file:~/.muse/muse.md}"
    }
  },
  "skills": {
    "paths": [
      "~/.skills",
      ".skills"
    ]
  }
}
