# Ignore everything
*

# Include README
!README.md

# Include git
!.gitignore
!.gitignore.global
!.gitconfig

# Include shell
!.zshrc
!.p10k.zsh
!antigen.zsh
!.antigenrc
!.condarc
!.tmux.conf
!.*rc
!*.aliases
!bin/**/*
!bin
bin/.*

# Include AWS
!.aws
!.aws/config
!.aws/amazonq
!.aws/amazonq/global_context.json
!.aws/amazonq/cli-agents
!.aws/amazonq/cli-agents/*

!.kiro
!.kiro/agents
!.kiro/agents/dev.json
!.kiro/settings
!.kiro/settings/*

# Claude
!.claude
!.claude/settings.json
!.claude/statusline.sh
!.claude/CLAUDE.md
!.claude/agents
!.claude/agents/*.md
!.claude/.mcp.json

# Skills
!.skills
!.skills/**

# OpenCode
!.config
!.config/opencode
!.config/opencode/opencode.json
!.config/opencode/skills
!.config/opencode/skills/**
!.opencode
!.opencode/commands
!.opencode/commands/*.md

# Explicitly ignore
.bashrc
.kiro/settings/mcp.json
