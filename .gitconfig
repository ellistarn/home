[user]
	name = Ellis Tarn
	email = ellistarn@gmail.com
	signingkey = /Users/etarn/.ssh/id_ecdsa.pub

[core]
	pager = less -FMRiX
	editor = vim
	excludesfile = /Users/etarn/.gitignore.global

[push]
	default = simple
	autoSetupRemote = true

[alias]
	graph = log --graph --all --pretty=format:\"%C(yellow)%h%Creset%C(cyan)%C(bold)%d%Creset %C(cyan)(%cr)%Creset %C(green)%<(12)%cn%Creset %s\"
	# Delete branches whose remote is gone, clean up their worktrees, and pull main
	gone = "!bash -c '[ \"$(git rev-parse --git-dir)\" = \".git\" ] || { echo \"error: must be in main worktree, not a linked worktree\"; exit 1; } && git fetch -p -q && current=$(git branch --show-current) && git branch -vv | grep \": gone]\" | sed \"s/^[*+] //\" | awk \"{print \\$1}\" | while read branch; do [ \"$branch\" = \"$current\" ] && continue; wt=$(git worktree list --porcelain | grep -B2 -E \"^branch refs/heads/$branch$\" | grep \"^worktree \" | sed \"s/^worktree //\"); if [ -n \"$wt\" ]; then git worktree remove \"$wt\" 2>&1 || { echo \"skip: $branch (dirty worktree: $wt)\"; continue; }; fi; git branch -D \"$branch\"; done && if git branch -vv | grep \"^\\*\" | grep -q \": gone]\"; then echo \"warning: current branch '\"'\"'$current'\"'\"' was deleted on remote\"; else git pull --ff-only; fi'"

[color]
	ui = auto

[credential]
	helper = osxkeychain
	UseHttpPath = true

[url "ssh://git@github.com/"]
	insteadOf = https://github.com/
[gpg]
	format = ssh

[includeIf "gitdir:~/workspaces/"]
	path = ~/.gitconfig-amazon
